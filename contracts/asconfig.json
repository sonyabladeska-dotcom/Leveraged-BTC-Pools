{
  "targets": {
    "release": {
      "outFile": "build/LeveragedBTCPools.wasm",
      "use": ["abort=src/index/abort"]
    }
  },
  "options": {
    "exportStart": "start",
    "transform": "@btc-vision/opnet-transform",
    "runtime": "stub",
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ]
  }
}
